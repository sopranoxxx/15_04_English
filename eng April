    { id: 77, de: "stehen", infinitive:["stand"], simplePast:["stood"], pastParticiple:["stood"] },
    { id: 78, de: "stehlen", infinitive:["steal"], simplePast:["stole"], pastParticiple:["stolen"] },
    { id: 79, de: "schwimmen", infinitive:["swim"], simplePast:["swam"], pastParticiple:["swum"] },
    { id: 80, de: "nehmen", infinitive:["take"], simplePast:["took"], pastParticiple:["taken"] },
    { id: 81, de: "unterrichten; lehren; beibringen", infinitive:["teach"], simplePast:["taught"], pastParticiple:["taught"] },
    { id: 82, de: "erzählen", infinitive:["tell"], simplePast:["told"], pastParticiple:["told"] },
    { id: 83, de: "(nach)denken; glauben", infinitive:["think"], simplePast:["thought"], pastParticiple:["thought"] },
    { id: 84, de: "werfen", infinitive:["throw"], simplePast:["threw"], pastParticiple:["thrown"] },
    { id: 85, de: "verstehen", infinitive:["understand"], simplePast:["understood"], pastParticiple:["understood"] },
    { id: 86, de: "(auf)wachen; (auf)wecken", infinitive:["wake up"], simplePast:["woke up"], pastParticiple:["woken up"] },
    { id: 87, de: "anhaben; tragen", infinitive:["wear"], simplePast:["wore"], pastParticiple:["worn"] },
    { id: 88, de: "gewinnen; siegen", infinitive:["win"], simplePast:["won"], pastParticiple:["won"] },
    { id: 89, de: "schreiben", infinitive:["write"], simplePast:["wrote"], pastParticiple:["written"] }
  ];

  function shuffle(arr){
    for(let i = arr.length - 1; i > 0; i--){
      const j = Math.floor(Math.random() * (i + 1));
      [arr[i], arr[j]] = [arr[j], arr[i]];
    }
    return arr;
  }

  function norm(s){
    return (s || "")
      .toString()
      .trim()
      .toLowerCase()
      .replace(/[’]/g, "'")
      .replace(/\s+/g, " ");
  }

  const GOAL = ITEMS.length;
  const STORAGE_KEY = "irregular_verbs_trainer_strict_v1";

  const dewordEl = document.getElementById("deword");
  const feedbackEl = document.getElementById("feedback");
  const progressText = document.getElementById("progressText");
  const progressNums = document.getElementById("progressNums");
  const reviewinfo = document.getElementById("reviewinfo");
  const qnEl = document.getElementById("qnum");
  const barEl = document.getElementById("bar");
  const bankBox = document.getElementById("bankBox");
  const statusEl = document.getElementById("status");

  const infWrap = document.getElementById("infWrap");
  const pastWrap = document.getElementById("pastWrap");
  const ppWrap = document.getElementById("ppWrap");

  const btnCheck = document.getElementById("btnCheck");
  const btnShow = document.getElementById("btnShow");
  const btnNext = document.getElementById("btnNext");
  const btnSkip = document.getElementById("btnSkip");
  const btnStatus = document.getElementById("btnStatus");
  const btnRestart = document.getElementById("btnRestart");

  const byId = (id) => ITEMS.find(x => x.id === id);

  function defaultState(){
    const ids = ITEMS.map(it => it.id);
    return {
      statusById: Object.fromEntries(ids.map(id => [id, 0])),
      mainQueue: shuffle([...ids]),
      reviewQueue: [],
      reviewDueAt: {},
      step: 0,
      currentId: null,
      finished: false
    };
  }

  function loadState(){
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if(!raw) return null;
      const parsed = JSON.parse(raw);
      if(!parsed || !parsed.statusById) return null;
      return parsed;
    } catch {
      return null;
    }
  }

  let state = loadState() || defaultState();

  function saveState(){
    localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
  }

  function countSolved(){
    return Object.values(state.statusById).filter(x => x === 1).length;
  }

  function countWrongOpen(){
    return Object.values(state.statusById).filter(x => x === 2).length;
  }

  function updateHeader(){
    const solved = countSolved();
    const wrongOpen = countWrongOpen();
    const percent = Math.round((solved / GOAL) * 100);

    progressText.textContent = `Fortschritt: ${percent}%`;
    progressNums.textContent = `${solved}/${GOAL} Verben richtig`;
    reviewinfo.textContent = wrongOpen ? `Wiederholung offen: ${wrongOpen}` : "";
    qnEl.textContent = state.currentId ? `Frage: ${state.step}` : "";
    barEl.style.width = `${Math.min(100, (solved / GOAL) * 100)}%`;
  }

  function renderStatus(){
    const solved = countSolved();
    const rows = ITEMS.map(it => {
      const st = state.statusById[it.id];
      const label = st === 1 ? "richtig" : (st === 2 ? "wiederholen" : "offen");
      return `${String(it.id).padEnd(3)} | ${it.infinitive.join(" / ").padEnd(16)} | ${label}`;
    }).join("\n");

    statusEl.textContent =
      `STATUS\n------\nRichtig: ${solved}/${GOAL}\n\n` +
      `ID  | INFINITIVE       | STATUS\n` +
      `-----------------------------------\n` +
      rows;
  }

  function enqueueReview(id){
    const due = state.step + 5;
    state.reviewDueAt[id] = Math.max(state.reviewDueAt[id] || 0, due);
    if(!state.reviewQueue.includes(id)) state.reviewQueue.push(id);
    state.statusById[id] = 2;
  }

  function removeFromReviewIfSolved(id){
    state.reviewQueue = state.reviewQueue.filter(x => x !== id);
    delete state.reviewDueAt[id];
  }

  function pickNextId(){
    const due = state.reviewQueue.filter(id => (state.reviewDueAt[id] ?? 0) <= state.step);
    if(due.length) return due[Math.floor(Math.random() * due.length)];

    while(state.mainQueue.length){
      const id = state.mainQueue.shift();
      if(state.statusById[id] !== 1) return id;
    }

    if(state.reviewQueue.length){
      let bestDue = Infinity;
      for(const id of state.reviewQueue){
        bestDue = Math.min(bestDue, state.reviewDueAt[id] ?? Infinity);
      }
      const best = state.reviewQueue.filter(id => (state.reviewDueAt[id] ?? Infinity) === bestDue);
      return best[Math.floor(Math.random() * best.length)];
    }

    return null;
  }

  function createInputs(container, values, prefix){
    container.innerHTML = "";
    values.forEach((_, idx) => {
      const input = document.createElement("input");
      input.type = "text";
      input.autocomplete = "off";
      input.id = `${prefix}-${idx}`;
      input.dataset.index = String(idx);
      container.appendChild(input);
    });
  }

  function getInputs(container){
    return Array.from(container.querySelectorAll("input"));
  }

  function compareField(userValues, acceptedValues){
    const cleanedUser = userValues.map(norm).filter(Boolean);
    const cleanedAccepted = acceptedValues.map(norm);

    if(cleanedAccepted.length === 1){
      return cleanedUser.length === 1 && cleanedUser[0] === cleanedAccepted[0];
    }

    if(cleanedUser.length !== cleanedAccepted.length) return false;

    const sortedUser = [...cleanedUser].sort();
    const sortedAccepted = [...cleanedAccepted].sort();

    return sortedUser.every((v, i) => v === sortedAccepted[i]);
  }

  function fillSolutions(item){
    const infInputs = getInputs(infWrap);
    const pastInputs = getInputs(pastWrap);
    const ppInputs = getInputs(ppWrap);

    item.infinitive.forEach((val, i) => { if (infInputs[i]) infInputs[i].value = val; });
    item.simplePast.forEach((val, i) => { if (pastInputs[i]) pastInputs[i].value = val; });
    item.pastParticiple.forEach((val, i) => { if (ppInputs[i]) ppInputs[i].value = val; });
  }

  function setInputsDisabled(disabled){
    [infWrap, pastWrap, ppWrap].forEach(wrap => {
      getInputs(wrap).forEach(input => input.disabled = disabled);
    });
  }

  function renderQuestion(){
    const next = pickNextId();

    if(next === null){
      state.finished = true;
      dewordEl.innerHTML = `Fertig! <span class="ok">Alles geschafft.</span>`;
      feedbackEl.innerHTML = `<span class="ok">Du hast alle Verben erledigt.</span>`;
      infWrap.innerHTML = "";
      pastWrap.innerHTML = "";
      ppWrap.innerHTML = "";
      btnCheck.disabled = true;
      btnShow.disabled = true;
      btnNext.disabled = true;
      btnSkip.disabled = true;
      updateHeader();
      renderStatus();
      saveState();
      return;
    }

    state.currentId = next;
    state.step += 1;

    const item = byId(next);

    dewordEl.textContent = item.de;

    createInputs(infWrap, item.infinitive, "inf");
    createInputs(pastWrap, item.simplePast, "past");
    createInputs(ppWrap, item.pastParticiple, "pp");

    setInputsDisabled(false);

    btnCheck.disabled = false;
    btnShow.disabled = false;
    btnSkip.disabled = false;
    btnNext.disabled = true;

    feedbackEl.innerHTML = `<span class="muted">Gib die drei Formen ein.</span>`;

    updateHeader();
    renderStatus();
    saveState();

    const firstInput = infWrap.querySelector("input");
    if (firstInput) firstInput.focus();
  }

  btnCheck.addEventListener("click", () => {
    if(state.finished || !state.currentId) return;

    const item = byId(state.currentId);

    const infUser = getInputs(infWrap).map(i => i.value);
    const pastUser = getInputs(pastWrap).map(i => i.value);
    const ppUser = getInputs(ppWrap).map(i => i.value);

    const infOk = compareField(infUser, item.infinitive);
    const pastOk = compareField(pastUser, item.simplePast);
    const ppOk = compareField(ppUser, item.pastParticiple);

    if(infOk && pastOk && ppOk){
      state.statusById[item.id] = 1;
      removeFromReviewIfSolved(item.id);
      feedbackEl.innerHTML = `<span class="ok">Richtig!</span>`;
    } else {
      enqueueReview(item.id);
      feedbackEl.innerHTML = `<span class="bad">Falsch.</span> <span class="pill">Wiederholung nach ≥ 5 Fragen</span>`;
    }

    btnNext.disabled = false;
    updateHeader();
    renderStatus();
    saveState();
  });

  btnShow.addEventListener("click", () => {
    if(state.finished || !state.currentId) return;

    const item = byId(state.currentId);
    enqueueReview(item.id);
    fillSolutions(item);
    setInputsDisabled(true);

    feedbackEl.innerHTML =
      `<div class="warn"><b>Lösung:</b><br>` +
      `Infinitive: ${item.infinitive.join(" / ")}<br>` +
      `Simple Past: ${item.simplePast.join(" / ")}<br>` +
      `Past Participle: ${item.pastParticiple.join(" / ")}</div>`;

    btnCheck.disabled = true;
    btnNext.disabled = false;

    updateHeader();
    renderStatus();
    saveState();
  });

  btnSkip.addEventListener("click", () => {
    if(state.finished || !state.currentId) return;

    const item = byId(state.currentId);
    enqueueReview(item.id);

    feedbackEl.innerHTML = `<span class="bad">Übersprungen.</span> <span class="pill">Wiederholung nach ≥ 5 Fragen</span>`;
    btnNext.disabled = false;

    updateHeader();
    renderStatus();
    saveState();
  });

  btnNext.addEventListener("click", () => {
    if(state.finished) return;
    renderQuestion();
  });

  btnStatus.addEventListener("click", renderStatus);

  btnRestart.addEventListener("click", () => {
    localStorage.removeItem(STORAGE_KEY);
    state = defaultState();
    statusEl.textContent = "";
    renderQuestion();
  });

  document.addEventListener("keydown", (e) => {
    if(e.key === "Enter" && !btnNext.disabled){
      btnNext.click();
    }
  });

  bankBox.innerHTML = ITEMS.map(it => {
    return `<div class="bankitem"><b>${it.infinitive.join(" / ")}</b> — ${it.simplePast.join(" / ")} — ${it.pastParticiple.join(" / ")} — ${it.de}</div>`;
  }).join("");

  updateHeader();
  renderStatus();
  renderQuestion();
});
</script>
</body>
</html>
