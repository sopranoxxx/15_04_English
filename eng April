    }
    .inputs input {
      flex: 1;
      min-width: 180px;
    }
    button {
      font-size: 16px;
      padding: 10px 12px;
      margin-top: 10px;
    }
    .row {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }
    .row button {
      flex: 1;
      min-width: 150px;
    }
    .ok {
      color: #0a7a0a;
      font-weight: 700;
    }
    .bad {
      color: #b00020;
      font-weight: 700;
    }
    .muted {
      color: #666;
    }
    .warn {
      background: #fff7e6;
      border: 1px solid #ffe0a3;
      padding: 10px;
      border-radius: 10px;
      color: #5b3b00;
      margin-top: 10px;
    }
    .pill {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 999px;
      border: 1px solid #ddd;
      font-size: 12px;
      margin-left: 8px;
    }
    .status {
      margin-top: 12px;
      white-space: pre-wrap;
      font-family: ui-monospace, Menlo, monospace;
      font-size: 13px;
    }
    details {
      margin-top: 10px;
    }
    details summary {
      cursor: pointer;
      user-select: none;
    }
    .bankitem {
      margin: 4px 0;
      line-height: 1.35;
    }
    .smallbtn {
      font-size: 14px;
      padding: 8px 10px;
    }
    .hintbox {
      margin-top: 10px;
      padding: 10px;
      border: 1px dashed #ccc;
      border-radius: 10px;
      background: #fcfcfc;
      color: #333;
    }
    noscript {
      display: block;
      margin-top: 10px;
      padding: 10px;
      border: 1px solid #d00;
      border-radius: 10px;
      color: #700;
    }
  </style>
</head>
<body>
  <h1>Irregular Verbs Trainer</h1>
  <p>
    Du siehst das <b>deutsche Wort</b>. Schreibe die drei englischen Formen:
    <b>Infinitive</b>, <b>Simple Past</b> und <b>Past Participle</b>.
    <br>
    Wenn im Buch für eine Form <b>zwei Varianten</b> stehen, erscheinen hier auch <b>zwei Eingabefelder</b>.
    Fehlerhafte Aufgaben kommen <b>erst nach mindestens 5 weiteren Fragen</b> wieder.
  </p>

  <noscript>
    JavaScript ist deaktiviert. Bitte diese Seite in einem Browser öffnen, der JavaScript erlaubt.
  </noscript>

  <div class="card">
    <div class="toprow">
      <div class="mini" id="progressText">Fortschritt: 0%</div>
      <div class="mini" id="progressNums"></div>
      <div class="mini" id="reviewinfo"></div>
      <div class="mini" id="qnum"></div>
    </div>

    <div class="barwrap">
      <div class="bar" id="bar"></div>
    </div>

    <div class="deword" id="deword">Lade Wort…</div>

    <div class="hintbox">
      Keine Hinweise oben. Nur unten in der Word Bank.
    </div>

    <div class="grid">
      <div class="field">
        <label>Infinitive</label>
        <div class="inputs" id="infWrap"></div>
      </div>

      <div class="field">
        <label>Simple Past</label>
        <div class="inputs" id="pastWrap"></div>
      </div>

      <div class="field">
        <label>Past Participle</label>
        <div class="inputs" id="ppWrap"></div>
      </div>
    </div>

    <div id="feedback" style="margin-top:10px;"></div>

    <div class="row">
      <button id="btnCheck" type="button">✅ Prüfen</button>
      <button id="btnShow" type="button">👁️ Lösung zeigen</button>
    </div>

    <div class="row">
      <button id="btnNext" type="button" disabled>➡️ Nächste Frage</button>
      <button id="btnSkip" type="button">⏭️ Überspringen</button>
    </div>

    <details>
      <summary>📚 Word Bank anzeigen</summary>
      <div class="hintbox" id="bankBox"></div>
    </details>

    <div class="row">
      <button id="btnStatus" class="smallbtn" type="button">📊 Status</button>
      <button id="btnRestart" class="smallbtn" type="button">🔄 Reset</button>
    </div>

    <div class="status" id="status"></div>
  </div>

<script>
document.addEventListener("DOMContentLoaded", () => {

